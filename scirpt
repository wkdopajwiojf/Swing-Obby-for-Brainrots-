-- [[ HELPERS ]] --
local function getTargetCFrame(obj)
    if not obj then return nil end
    return obj:IsA("BasePart") and obj.CFrame or (obj:IsA("Model") and (obj.PrimaryPart and obj.PrimaryPart.CFrame or obj:GetModelCFrame()))
end

local function isIgnored(item)
    return string.find(item.Name:lower(), "bat") ~= nil
end

local function isItemLocked(item)
    if isIgnored(item) then return true end
    local itemName = string.gsub(item.Name:lower(), "%s+", "") -- ตัดช่องว่างออก
    for protectedName, isLocked in pairs(protectedUnits) do
        if isLocked then
            local cleanProtected = string.gsub(protectedName:lower(), "%s+", "") -- ตัดช่องว่างชื่อที่ล็อค
            if string.find(itemName, cleanProtected) then return true end
        end
    end
    return false
end

-- [[ RUNTIME STORAGE PROCESSOR ]] --
task.spawn(function()
    while task.wait(Config.SyncSpeed) do
        if not autoSellActive then continue end
        local char = player.Character; local bp = player:FindFirstChild("Backpack")
        if not char or not bp then continue end

        -- 1. ตรวจสอบไอเทมในมือ (Character)
        for _, item in pairs(char:GetChildren()) do
            if item:IsA("Tool") then
                if isIgnored(item) then continue end
                
                if isItemLocked(item) then 
                    -- ถ้าเป็นตัวล็อค ย้ายลงกระเป๋าทันที
                    item.Parent = bp 
                else
                    -- ** Double Check Logic **
                    task.wait(0.05) -- จังหวะหายใจให้ระบบอัปเดตสถานะชื่อ
                    if not isItemLocked(item) then
                        local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("SellBrainrot")
                        if remote then 
                            remote:FireServer("Single") 
                        end
                    end
                end
                task.wait(0.05) -- กัน Remote Spam
            end
        end

        -- 2. ตรวจสอบไอเทมในกระเป๋า (Backpack) เพื่อดึงมาขาย
        local handBusy = false
        for _, item in pairs(char:GetChildren()) do 
            if item:IsA("Tool") and not isIgnored(item) then 
                handBusy = true break 
            end 
        end

        if not handBusy then
            for _, item in pairs(bp:GetChildren()) do
                if item:IsA("Tool") and not isIgnored(item) and not isItemLocked(item) then
                    item.Parent = char
                    break -- ดึงมาขายทีละชิ้นตามคิว
                end
            end
        end
    end
end)

