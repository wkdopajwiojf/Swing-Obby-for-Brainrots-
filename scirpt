-- [[ MOVEMENT & SWEEPER ENGINE ]] --
local function findTargetUnit()
    local folder = workspace:FindFirstChild(Config.ActiveFolder)
    if not folder then return nil end
    for _, hitbox in pairs(folder:GetChildren()) do
        if hitbox.Name == "ServerHitbox" then
            for unitName, isSelected in pairs(selectedUnits) do
                if isSelected and hitbox:FindFirstChild(unitName) then return hitbox end
            end
        end
    end
    return nil
end

local function createSweepLog(zonePos)
    local folder = workspace:FindFirstChild(Config.ActiveFolder)
    if not folder then return end
    
    sweepLog = {} -- ล้าง Log เก่าเพื่อเริ่มรอบใหม่
    local children = folder:GetChildren()
    
    for i = 1, #children do
        local hitbox = children[i]
        if hitbox.Name == "ServerHitbox" then
            local cf = getTargetCFrame(hitbox)
            if cf then
                local dist = (zonePos - cf.Position).Magnitude
                if dist < 200 then 
                    table.insert(sweepLog, hitbox) -- บันทึกเข้าคิว
                end
            end
        end
    end
    
    if #sweepLog > 0 then
        isSweepingLog = true
        print("--------------------------------")
        print("[System]: สร้าง Log ใหม่สำเร็จ!")
        print("[System]: พบ Units ในระยะ 200 เมตร จำนวน " .. #sweepLog .. " ตัว")
        print("--------------------------------")
    else
        isSweepingLog = false
    end
end

local function getTargetFromLog()
    if #sweepLog == 0 then 
        if isSweepingLog then
            print("[System]: ---> เคลียร์ Log ทั้งหมดเรียบร้อย <---")
            isSweepingLog = false 
        end
        return nil 
    end
    
    -- วนเช็คจากหลังมาหน้าเพื่อดึงตัวที่ยังมีตัวตนอยู่จริง
    for i = #sweepLog, 1, -1 do
        local obj = sweepLog[i]
        if obj and obj.Parent == workspace:FindFirstChild(Config.ActiveFolder) then
            return obj -- ส่งเป้าหมายออกไป
        else
            -- ถ้าตัวนี้ไม่อยู่แล้ว (โดนเก็บหรือหายไป) ให้ลบออกจากโพย
            table.remove(sweepLog, i)
        end
    end
    
    return nil
end

RunService.Stepped:Connect(function()
    local char = player.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local folder = workspace:FindFirstChild(Config.ActiveFolder)
    if folder then
        for _, hitbox in pairs(folder:GetChildren()) do
            if hitbox.Name == "ServerHitbox" then
                local prompt = hitbox:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt and (root.Position - hitbox.Position).Magnitude <= Config.InteractRange then
                    prompt.HoldDuration = 0; prompt:InputHoldBegin(); task.wait(0.01); prompt:InputHoldEnd()
                end
            end
        end
    end
end)

task.spawn(function()
    while task.wait(Config.ScanInterval) do
        local char = player.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        
        local rareTarget = findTargetUnit()
        if rareTarget then
            root.CFrame = getTargetCFrame(rareTarget)
            status.Text = "COLLECTING RARE: " .. rareTarget.Name
            task.wait(Config.SyncSpeed)
        elseif currentActiveZone then
            local zoneObj = workspace:FindFirstChild(Config.ZoneFolder) and workspace[Config.ZoneFolder]:FindFirstChild(currentActiveZone)
            if zoneObj then
                local zCF = getTargetCFrame(zoneObj)
                local distToZone = (root.Position - zCF.Position).Magnitude
                
                if distToZone > 15 then
                    root.CFrame = zCF + Vector3.new(0, Config.PatrolHeight, 0)
                    status.Text = "WARPING TO ZONE"
                else
                    -- แก้ไขตรงนี้: ถ้ายังมีของใน Log (isSweepingLog เป็น true) ห้ามสแกนใหม่เด็ดขาด
                    if not isSweepingLog or #sweepLog == 0 then
                        -- ตรวจสอบซ้ำอีกครั้งว่าไม่มีของค้างจริงๆ ก่อนสร้างใหม่
                        if #sweepLog == 0 then
                            createSweepLog(zCF.Position)
                        end
                    end
                    
                    local target = getTargetFromLog()
                    if target then
                        root.CFrame = getTargetCFrame(target)
                        status.Text = "LOG CLEARING: " .. #sweepLog .. " LEFT"
                    else
                        -- ถ้าสแกนแล้วไม่มีตัวจริงๆ ให้รอที่จุด Standby
                        root.CFrame = zCF + Vector3.new(0, Config.PatrolHeight, 0)
                        status.Text = "WAITING FOR NEW UNITS..."
                    end
                end
            end
            task.wait(Config.ZoneSweepSpeed)
        else
            status.Text = "IDLE"
            if isSweepingLog or #sweepLog > 0 then
                sweepLog = {}
                isSweepingLog = false
                print("[System]: หยุดทำงาน - ล้างข้อมูลค้างคา")
            end
        end
    end
end)
