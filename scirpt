-- [[ RUNTIME LOOPS (MOVEMENT) ]] --
RunService.Stepped:Connect(function()
    local char = player.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local activeFolder = workspace:FindFirstChild(Config.ActiveFolder)
    if not activeFolder then return end
    for _, obj in pairs(activeFolder:GetChildren()) do
        local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt and getTargetCFrame(obj) and (root.Position - getTargetCFrame(obj).Position).Magnitude <= Config.InteractRange then
            prompt.HoldDuration = 0; prompt:InputHoldBegin(); task.wait(0.1); prompt:InputHoldEnd()
        end
    end
end)

task.spawn(function()
    while task.wait(Config.ScanInterval) do
        local char = player.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        local mainFolder = workspace:FindFirstChild(Config.MainFolder)
        local target = nil
        if mainFolder then
            local minDist = math.huge
            for _, item in pairs(mainFolder:GetChildren()) do
                if selectedUnits[item.Name] then
                    local cf = getTargetCFrame(item)
                    if cf and (root.Position - cf.Position).Magnitude < minDist then minDist = (root.Position - cf.Position).Magnitude; target = item end
                end
            end
        end
        if target then root.CFrame = getTargetCFrame(target); status.Text = "Credit by เด็กกะโปโล: "..target.Name
        elseif #patrolList > 0 then
            local zoneNum = patrolList[patrolIdx]
            local zObj = workspace:FindFirstChild(Config.ZoneFolder) and workspace[Config.ZoneFolder]:FindFirstChild(tostring(zoneNum))
            if zObj then
                root.CFrame = getTargetCFrame(zObj) + Vector3.new(0, Config.PatrolHeight, 0)
                status.Text = "ZONE: "..zoneNum
                if #patrolList > 1 then patrolIdx = patrolIdx + patrolDir
                    if patrolIdx > #patrolList then patrolIdx = #patrolList-1; patrolDir = -1 elseif patrolIdx < 1 then patrolIdx = 2; patrolDir = 1 end
                else patrolIdx = 1 end
            end
        else status.Text = "IDLE" end
    end
end)
