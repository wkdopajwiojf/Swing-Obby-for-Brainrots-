-- [[ SAVE/LOAD SYSTEM ]] --
local function saveConfig()
    local data = {
        selectedUnits = selectedUnits,
        protectedUnits = protectedUnits,
        selectedZones = selectedZones,
        autoSellActive = autoSellActive
    }
    local success, json = pcall(function() return HttpService:JSONEncode(data) end)
    if success then
        writefile(Config.SaveFileName, json)
    end
end

local function loadConfig()
    if isfile(Config.SaveFileName) then
        local success, data = pcall(function() 
            return HttpService:JSONDecode(readfile(Config.SaveFileName)) 
        end)
        if success then
            selectedUnits = data.selectedUnits or {}
            protectedUnits = data.protectedUnits or {}
            selectedZones = data.selectedZones or {}
            autoSellActive = data.autoSellActive or false
            
            -- อัปเดต Patrol List หลังโหลด
            patrolList = {}; for z,v in pairs(selectedZones) do if v then table.insert(patrolList, tonumber(z)) end end
            table.sort(patrolList)
        end
    end
end

