-- [[ SAVE/LOAD SYSTEM ]] --
local function saveConfig()
    local data = {selectedUnits = selectedUnits, protectedUnits = protectedUnits, selectedZones = selectedZones, autoSellActive = autoSellActive}
    local success, json = pcall(function() return HttpService:JSONEncode(data) end)
    if success then writefile(Config.SaveFileName, json) end
end

local function loadConfig()
    if isfile(Config.SaveFileName) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(Config.SaveFileName)) end)
        if success then
            selectedUnits = data.selectedUnits or {};
            protectedUnits = data.protectedUnits or {}; 
            selectedZones = data.selectedZones or {};
            autoSellActive = data.autoSellActive or false
            for z, v in pairs(selectedZones) do if v then currentActiveZone = z break end end
        end
    end
end
loadConfig()

-- [[ HELPERS ]] --
local function getTargetCFrame(obj)
    if not obj then return nil end
    return obj:IsA("BasePart") and obj.CFrame or (obj:IsA("Model") and (obj.PrimaryPart and obj.PrimaryPart.CFrame or obj:GetModelCFrame()))
end

local function isItemLocked(item)
    if item.Name == "Bat" then return true end
    local itemName = string.gsub(item.Name:lower(), "%s+", "")
    for protectedName, isLocked in pairs(protectedUnits) do
        if isLocked then
            local cleanName = string.gsub(protectedName:lower(), "%s+", "")
            if itemName == cleanName or itemName == cleanName.."_tool" then return true end
        end
    end
    return false
end

